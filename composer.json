{
    "name": "anibalealvarezs/api-client-skeleton",
    "description": "Base skeleton for standardizing PHP API clients with advanced error handling and data normalization.",
    "license": "MIT",
    "keywords": ["api", "client", "skeleton", "sdk", "normalization", "error-handling"],
    "homepage": "https://github.com/anibalealvarezs/api-client-skeleton",
    "authors": [
        {
            "name": "Aníbal Álvarez",
            "email": "anibalealvarezs@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/anibalealvarezs/api-client-skeleton/issues"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "symfony/yaml": "^5.4.10 || ^6.0 || ^7.0",
        "nesbot/carbon": "^2.61 || ^3.0",
        "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0",
        "doctrine/collections": "^1.6 || ^2.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "anibalealvarezs/oauth-v1": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../OAuth-v1",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://satis.anibalalvarez.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anibalealvarezs\\ApiSkeleton\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "fakerphp/faker": "^1.20",
        "phpunit/phpunit": "^9",
        "phpstan/phpstan": "^1.10"
    },
    "minimum-stability": "dev",
    "prefer-stable": false
}